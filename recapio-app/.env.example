# Cloud Storage (Optional - Required for Vercel Serverless deployments. Default fallback: local filesystem)
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_BUCKET="Audio" # Must be created with "public" access enabled inside Supabase console

