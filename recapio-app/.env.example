# Recapio — Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection string (Neon or Supabase recommended for MVP)
DATABASE_URL="postgresql://postgres:recapioDatabase@db.ythuwvmroyjpqrtvvzii.supabase.co:5432/postgres"

# AI Credentials
OPENAI_API_KEY="your-openai-api-key"
